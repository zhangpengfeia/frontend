{
  "manifest_version": 3,
  "name": "前端Vue3框架开发浏览器插件",
  "version": "0.0.1",
  "description": "前端Vue3框架开发浏览器插件",
  "icons": {
    "16": "icon-16.png",
    "32": "icon-32.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  },
  "action": {
    "default_popup": "index.html",
    "default_icon": {
      "16": "icon-16.png",
      "32": "icon-32.png",
      "48": "icon-48.png",
      "128": "icon-128.png"
    }
  },
  "host_permissions": ["http://localhost:*/*","http://127.0.0.1:*/*"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/content.ts"]
    }
  ],
  "background": {
    "service_worker": "src/background/service_worker.ts"
  }
}